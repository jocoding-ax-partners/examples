---
import Layout from "../layouts/Layout.astro";
import { axhub } from "../lib/axhub";

let upstream: { status: number; body: unknown } | null = null;
let error: string | null = null;

if (axhub.isConfigured) {
  try {
    const res = await axhub.fetch("/v1/me");
    const body = await res.json().catch(() => null);
    upstream = { status: res.status, body };
  } catch (err) {
    error = String(err);
  }
}

const ts = new Date().toISOString();
---

<Layout title="SSR 데모 — axhub × Astro">
  <main>
    <h1>SSR 데모</h1>
    <p>
      이 페이지는 매 요청마다 서버에서 렌더돼요. 시간:
      <code>{ts}</code>
    </p>

    {!axhub.isConfigured && (
      <div class="warn-card">
        axhub 환경변수가 설정되지 않았어요. <code>.env</code> 또는 axhub 배포 환경을 확인해 주세요.
      </div>
    )}

    {error && (
      <div class="warn-card">
        호출 에러: <code>{error}</code>
      </div>
    )}

    {upstream && (
      <section class="result">
        <h2>axhub.fetch("/v1/me") 응답</h2>
        <p>HTTP <strong>{upstream.status}</strong></p>
        <pre>{JSON.stringify(upstream.body, null, 2)}</pre>
      </section>
    )}

    <p><a href="/">← 홈으로</a></p>
  </main>
</Layout>

<style>
  main {
    max-width: 720px;
    margin: 4rem auto;
    padding: 0 1rem;
  }
  .warn-card {
    margin: 1rem 0;
    padding: 1rem;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 0.5rem;
    color: #92400e;
  }
  .result pre {
    background: #f3f4f6;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    font-size: 0.85rem;
  }
</style>
